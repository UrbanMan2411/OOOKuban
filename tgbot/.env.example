# Telegram
BOT_TOKEN=123456:ABC-replace-me
ADMIN_TG_IDS=111111111,222222222

# OpenAI-совместимый LLM-эндпоинт
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o-mini

# Whisper
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=ru

# Пути
DATA_DIR=./data

# Telemost — дефолтная ссылка хоста (если у юзера не привязана через /meet_link)
DEFAULT_TELEMOST_URL=

# Listener (макос)
AUDIO_INPUT_DEVICE=BlackHole 2ch
LISTENER_HARD_CAP_MINUTES=180
LISTENER_IDLE_MINUTES=5
HEADLESS=false

# Имя, под которым бот заходит в звонок
LISTENER_DISPLAY_NAME=📝 GP Notetaker

# Логирование
LOG_LEVEL=INFO
