# → /opt/greenpanda/cockpit/.env on the server. Fill in, keep secret.

# Self-host storage (filesystem) + public origin of the cockpit app.
STORAGE_DIR=/var/lib/greenpanda/cockpit
PUBLIC_BASE=https://app.__DOMAIN__
PORT=3000

# Dashboard login (cookie holds sha256, not the password).
COCKPIT_PASSWORD=

# Marketplaces (для синхронизации каталога и аналитики).
WB_TOKEN=
OZON_CLIENT_ID=
OZON_API_KEY=

# Telegram-магазин. Без них — демо-режим (заказ без онлайн-оплаты).
TG_BOT_TOKEN=
TG_PROVIDER_TOKEN=
TG_WEBHOOK_SECRET=
SHOP_URL=https://app.__DOMAIN__/shop

# Не задавайте BLOB_READ_WRITE_TOKEN на сервере — иначе включится облачный режим
# вместо файлового хранилища.
